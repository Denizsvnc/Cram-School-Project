{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "build/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm run build-electron && wait-on http://localhost:5173 && NODE_ENV=development electron . --no-sandbox --ozone-platform=x11 --disable-gpu\"",
    "electron": "electron build/main.cjs",
    "build-electron": "tsc -p electron/tsconfig.electron.json && mv build/main.js build/main.cjs && mv build/preload.js build/preload.cjs",
    "build": "tsc -b && vite build && npm run build-electron",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "axios": "^1.13.6",
    "json-server": "^1.0.0-beta.13",
    "jwt-decode": "^4.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/electron": "^1.4.38",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "wait-on": "^9.0.4"
  }
}
